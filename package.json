{
  "name": "@emfts/vue-registry",
  "version": "0.0.1-next.1",
  "type": "module",
  "description": "Vue 3 component registry for EMFTS (EMF TypeScript) with priority-based component selection",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@emfts/core": "^0.1.1-next.2",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.4"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "keywords": [
    "emf",
    "ecore",
    "vue",
    "component-registry",
    "model-driven",
    "emfts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "EPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-fennec/emf.ts.vue.registry"
  }
}
